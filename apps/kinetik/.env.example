# Kinetik — copy to .env.local and paste your real Supabase values.
# These are the SAME project as ArgantaLab (one Supabase, namespaced kinetik_* tables).
# The anon key is meant to ship in the client; keep .env.local out of git anyway.

VITE_SUPABASE_URL=https://YOURREF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...
