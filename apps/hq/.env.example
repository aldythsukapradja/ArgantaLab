# Reuse the ArgantaLab Supabase project (org vypixumgjefvaplxromd).
# Copy this file to .env.local and paste the real values from the
# Supabase dashboard (Project Settings -> API).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Where the built-in (Featured) games are hosted — the ArgantaLab deployment.
# Used by Game Builder's Featured group to open games in a new tab.
VITE_ARGANTA_URL=https://argantalab.vercel.app
